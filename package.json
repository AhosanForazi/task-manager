{
  "name": "task-management-api",
  "version": "1.0.0",
  "description": "CRUD REST API for a Task Management System using Node.js, Express, SQLite, and Knex.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node src/app.js",
    "migrate": "knex --knexfile knexfile.js migrate:latest",
    "rollback": "knex --knexfile knexfile.js migrate:rollback",
    "seed": "set NODE_ENV=production&& node seed.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "express",
    "sqlite",
    "knex",
    "crud",
    "rest-api",
    "tasks"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.2.3",
    "knex": "^3.3.0",
    "pg": "^8.22.0"
  }
}
